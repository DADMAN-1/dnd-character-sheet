  addMythologicalFigure: (entry: MythologicalFigure) -> (text);
  addNPC: (npc: NPC) -> ();
  addOfficerDuel: (armyId: text, duel: OfficerDuel) -> ();
  addPactContractEntry: (entry: PactContractEntry) -> (text);
