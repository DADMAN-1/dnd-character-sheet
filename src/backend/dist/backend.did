  deleteAllianceTreaty: (id: text) -> (bool);
  deleteAlly: (id: nat) -> ();
  deleteAmnesticLogEntry: (id: text) -> (bool);
  deleteAncientHistoryEntry: (id: text) -> (bool);
  deleteAngelClassEntry: (id: text) -> (bool);
