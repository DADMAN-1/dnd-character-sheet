service : {
  _initializeAccessControl: () -> ();
  addAllianceTreaty: (entry: AllianceTreaty) -> (text);
  addAlly: (characterId: CharacterId, name: text, relationship: text, notes:
   text) -> (nat);
  addAmnesticLogEntry: (entry: AmnesticLogEntry) -> (text);
  addAncientHistoryEntry: (entry: AncientHistoryEntry) -> (text);
  addAngelClassEntry: (entry: AngelClassEntry) -> (text);
  addAnomalyExposureEntry: (entry: AnomalyExposureEntry) -> (text);
  addArmy: (input: ArmyInput) -> (text);
  addArmyDoctrine: (entry: ArmyDoctrine) -> (text);
  addArmyLootEntry: (armyId: text, entry: ArmyLootEntry) -> (text);
  addArmyMoraleEvent: (armyId: text, event: ArmyMoraleHistoryEntry) -> (bool);
  addArmyRivalEntry: (entry: ArmyRivalEntry) -> (text);
  addAscensionLogEntry: (entry: AscensionLogEntry) -> (text);
  addAttunedItem: (characterId: CharacterId, item: AttunedItem) -> ();
  addBattleEngagement: (armyId: text, engagement: BattleEngagement) -> ();
  addBattleOutcome: (entry: BattleOutcome) -> (nat);
  addBestiaryCreature: (entry: BestiaryCreature) -> (nat);
  addBetrayalLogEntry: (entry: BetrayalLogEntry) -> (text);
  addBlackBudgetEntry: (entry: BlackBudgetEntry) -> (text);
  addBloodOathEntry: (entry: BloodOathEntry) -> (text);
  addBloodlineEntry: (entry: BloodlineEntry) -> (text);
  addBountyObjective: (armyId: text, obj: BountyObjective) -> (text);
  addCalendarEvent: (entry: CalendarEvent) -> (nat);
  addCampaign: (campaign: Campaign) -> ();
  addCampaignEnemy: (campaignId: text, enemy: CampaignEnemy) -> (text);
  addCapturedEnemy: (entry: CapturedEnemy) -> (nat);
  addCelestialBlessing: (entry: CelestialBlessingEntry) -> (text);
  addCharacterAbility: (ability: CharacterAbility) -> (CharacterAbilityId);
  addCharacterCustomStat: (characterId: CharacterId, statId: nat, statName:
   text, value: text) -> (nat);
  addCharacterFeat: (characterId: CharacterId, name: text, description:
   text) -> (nat);
  addCharacterInjury: (characterId: CharacterId, injury: CharacterInjury) ->
   (text);
  addCharacterLegacy: (entry: CharacterLegacy) -> (text);
  addCharacterPhysicalAttack: (attack: CharacterPhysicalAttack) ->
   (CharacterPhysicalAttackId);
  addCharacterProficiency: (characterId: CharacterId, profType: text, name:
   text) -> (nat);
  addCharacterRelationship: (entry: CharacterRelationship) -> (nat);
  addCharacterSkill: (characterId: CharacterId, skillName: text, proficient:
   bool, expertise: bool) -> (nat);
  addClass: (cls: CustomClass) -> (ClassId);
  addClearanceLevelEntry: (entry: ClearanceLevelEntry) -> (text);
  addCommendation: (entry: Commendation) -> (text);
  addContainmentBreachEntry: (entry: ContainmentBreachEntry) -> (text);
  addCorruptionLogEntry: (entry: CorruptionLogEntry) -> (text);
  addCourtMartialEntry: (entry: CourtMartialEntry) -> (text);
  addCursedItemEntry: (entry: CursedItemEntry) -> (text);
  addCustomAbility: (ability: CustomAbility) -> (CustomAbilityId);
  addCustomFeat: (name: text, description: text, prerequisites: text) ->
   (nat);
  addCustomItem: (item: CustomItem) -> (CustomItemId);
  addCustomPhysicalAttack: (attack: CustomPhysicalAttack) ->
   (CustomPhysicalAttackId);
  addCustomSkill: (name: text, statBased: text, description: text) -> (nat);
  addCustomSpell: (spell: CustomSpell) -> (CustomSpellId);
  addCustomSpellSchool: (school: CustomSpellSchool) -> (CustomSpellSchoolId);
  addCustomStat: (name: text, description: text, defaultValue: text) -> (nat);
  addDarkRitualEntry: (entry: DarkRitualEntry) -> (text);
  addDefectionEntry: (entry: DefectionEntry) -> (text);
  addDemonClassEntry: (entry: DemonClassEntry) -> (text);
  addDeploymentNote: (armyId: text, note: DeploymentMapNote) -> (text);
  addDiplomacyEntry: (armyId: text, entry: DiplomacyEntry) -> (text);
  addDivineMandate: (entry: DivineMandateEntry) -> (text);
  addDreamVisionEntry: (entry: DreamVisionEntry) -> (text);
  addEncounterEntry: (entry: EncounterEntry) -> ();
  addEnemyProfile: (armyId: text, profile: EnemyProfile) -> (text);
  addEspionageEntry: (entry: EspionageEntry) -> (text);
  addEthicsReviewEntry: (entry: EthicsReviewEntry) -> (text);
  addFaction: (entry: Faction) -> (nat);
  addFallenSoldier: (entry: FallenSoldierEntry) -> (text);
  addGainLossEntry: (armyId: text, entry: GainLossEntry) -> (text);
  addHolyRelic: (entry: HolyRelicEntry) -> (text);
  addHolyWarEntry: (entry: HolyWarEntry) -> (text);
  addInfernalDebtEntry: (entry: InfernalDebtEntry) -> (text);
  addInterPresetWarEntry: (entry: InterPresetWarEntry) -> (text);
  addItem: (item: InventoryItem) -> (InventoryItemId);
  addLanguage: (characterId: CharacterId, name: text) -> (nat);
  addLocation: (loc: Location) -> ();
  addLootDistributionEntry: (entry: LootDistributionEntry) -> (bool);
  addLoreEntry: (entry: LoreEntry) -> ();
  addLostKnowledgeEntry: (entry: LostKnowledgeEntry) -> (text);
